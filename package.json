{
  "name": "educom",
  "version": "1.0.0",
  "description": "Build a working computer from a single NAND gate — a no-build TypeScript simulator you learn by climbing, gate by gate, up to a CPU.",
  "type": "module",
  "bin": {
    "educom": "./bin/educom.mjs"
  },
  "scripts": {
    "educom": "node --experimental-strip-types src/cli.ts",
    "start": "node --experimental-strip-types src/cli.ts serve workbench/0-simple-and.compute",
    "serve": "node --experimental-strip-types src/cli.ts serve",
    "run": "node --experimental-strip-types src/cli.ts run",
    "tick": "node --experimental-strip-types src/cli.ts tick",
    "table": "node --experimental-strip-types src/cli.ts table",
    "info": "node --experimental-strip-types src/cli.ts info",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types test/run.ts"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
